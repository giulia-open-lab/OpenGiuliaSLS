    "version": "2.0.0",
    "tasks": [
        {
            "label": "Documentation - Build HTML",
            "type": "shell",
            "command": "make -C docs html",
            "group": "build",
            "icon": {"id": "archive"}
        },
        {
            "label": "Documentation - Run Development",
            "type": "shell",
            "command": "docker compose -f ${workspaceFolder}/docs/docker-compose.dev.yml up",
            "group": "none",
            "icon": {"id": "run"}
        }
    ]
}